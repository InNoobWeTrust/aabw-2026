# Authentication
# Primary: separate passwords for judge and admin roles.
JUDGE_ACCESS_PASSWORD=change-me
ADMIN_ACCESS_PASSWORD=change-me-admin
# Legacy fallback — used only when JUDGE_ACCESS_PASSWORD is not set.
# ACCESS_PASSWORD=change-me-to-a-strong-password
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_EXPIRY_HOURS=24

# Pipeline
MAX_VIDEO_DURATION_SECONDS=30
MAX_VIDEO_SIZE_MB=100
TARGET_ROBOT=franka_panda

# Data
# Root for jobs/, queue/, and all persistent state.
# Production (Docker/Render): /app/data
# Local development: ./data
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO

# Agent Reviews / Calibration / Assistant
# Preferred: generic OpenAI-compatible provider config.
# Examples: DeepSeek, MiniMax, Featherless, or any provider exposing /v1/chat/completions.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com
LLM_MODEL_NAME=

# Backward-compatible fallback fields.
# If LLM_* is unset, the app will fall back to these Featherless-specific values.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai
FEATHERLESS_MODEL_NAME=kimi-k2

# Legacy Daytona fields are no longer used by runtime execution.
# They are intentionally omitted from the example to avoid suggesting extra setup.
REVIEW_TIMEOUT_SECONDS=60
REVIEW_MAX_CONTEXT_CHARS=24000
REVIEW_STREAM_CHUNK_CHARS=240
ASSISTANT_MAX_TURNS=6
ASSISTANT_MAX_MESSAGES=24
ASSISTANT_MAX_CONTEXT_CHARS=20000

# Server
HOST=0.0.0.0
PORT=8000
